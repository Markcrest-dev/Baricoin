generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  name         String?
  username     String        @unique
  phone        String?
  password     String
  isVerified   Boolean       @default(false)
  kycStatus    String        @default("unverified")
  memberSince  DateTime      @default(now())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  referredBy   Referral?     @relation("UserReferred")
  referrals    Referral[]    @relation("UserReferrer")
  transactions Transaction[]
  wallets      Wallet[]
}

model Wallet {
  id        String   @id @default(uuid())
  currency  String
  balance   Float    @default(0)
  label     String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model Transaction {
  id          String   @id @default(uuid())
  type        String
  amount      Float
  currency    String
  status      String   @default("pending")
  description String?
  userId      String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model Referral {
  id         String   @id @default(uuid())
  referrerId String
  referredId String   @unique
  reward     Float    @default(0)
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  referred   User     @relation("UserReferred", fields: [referredId], references: [id])
  referrer   User     @relation("UserReferrer", fields: [referrerId], references: [id])
}
